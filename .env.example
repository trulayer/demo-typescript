# Copy to `.env` and fill in your keys.
# Any example that hits a real provider reads these at startup.

# --- TruLayer -------------------------------------------------------------
TRULAYER_API_KEY=tl_your_key_here
TRULAYER_PROJECT_NAME=demo
TRULAYER_ENDPOINT=https://api.trulayer.ai

# --- Providers ------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- LangChain / LangSmith (optional) -------------------------------------
# LangSmith is LangChain's own observability product. TruLayer and
# LangSmith record via separate callback paths and can run side by side.
# Leave these unset to skip LangSmith; TruLayer tracing works either way.
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=trulayer-demos

# --- Offline / CI mode ----------------------------------------------------
# Set to true to route OpenAI / Anthropic through a mock `fetch`
# (no network, no real API keys required). Used by `run-all.ts` and
# the test suite. Either variable works.
# TRULAYER_DRY_RUN=true
# TRULAYER_DEMO_MOCK=1
