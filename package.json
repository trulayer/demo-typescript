{
  "name": "trulayer-demo-typescript",
  "version": "0.0.0",
  "private": true,
  "description": "End-to-end TypeScript examples for the TruLayer AI SDK",
  "type": "module",
  "scripts": {
    "example": "tsx",
    "basic-trace": "tsx examples/basic-trace.ts",
    "openai-auto": "tsx examples/openai-auto.ts",
    "anthropic-auto": "tsx examples/anthropic-auto.ts",
    "rag-pipeline": "tsx examples/rag-pipeline.ts",
    "agent": "tsx examples/agent.ts",
    "langchain-chain": "tsx examples/langchain-chain.ts",
    "streaming": "tsx examples/streaming.ts",
    "feedback": "tsx examples/feedback.ts",
    "run-all": "tsx examples/run-all.ts",
    "mock-server": "tsx examples/mock-server.ts",
